<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF xmlns:bsml="http://www.biosignalml.org/ontologies/2011/04/biosignalml#" xmlns:dct="http://purl.org/dc/terms/" xmlns:dctype="http://purl.org/dc/dcmitype/" xmlns:opb="http://bhi.washington.edu/OPB#" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:prv="http://purl.org/net/provenance/ns#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:time="http://www.w3.org/2006/time#" xmlns:uome-core="http://www.sbpax.org/uome/core.owl#" xmlns:xml="http://www.w3.org/XML/1998/namespace" xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml">
    <owl:versionInfo>0.93.5</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/subject">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Recording">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Recording">
    <rdf:type rdf:resource="http://purl.org/net/provenance/ns#DataItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Recording">
    <dct:description>A collection of Signals held as a named entity, all pertaining to one thing
          (the subject) and which have been recorded in the same session.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal">
    <dct:description>A sequence of periodic measurements of some physical quantity, ordered by some sampling
           dimension, normally time. A Signal is part of some Recording.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal">
    <rdfs:subClassOf rdf:resource="http://bhi.washington.edu/OPB#OPB01015"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Segment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Segment">
    <dct:description>A portion of a Signal or Recording, defined by restricting samples to some
           interval in the sampling dimension.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Event">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Event">
    <dct:description>Something that has occurred in time, possibly for some duration.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Event">
    <rdfs:subClassOf rdf:resource="http://bhi.washington.edu/OPB#OPB01060"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Annotation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Annotation">
    <dct:description>A general note, comment, or qualitative measure about the whole of,
           or some portion of, a Recording, Signal or Event.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UniformSignal">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UniformSignal">
    <dct:description>A signal that has been sampled at a constant rate.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UniformSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SampleClock">
    <dct:description>An increasing sequence of sample coordinates.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SampleClock">
    <rdfs:comment>Several signals may use the same clock.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SampleClock">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter">
    <dct:description>The class of filter that has been applied to a signal during data collection.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#BP_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#BP_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#BP_Filter">
    <dct:description>A band-pass filter.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#HP_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#HP_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#HP_Filter">
    <dct:description>A high-pass filter.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#LP_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#LP_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#LP_Filter">
    <dct:description>A low-pass filter.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Notch_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Notch_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Notch_Filter">
    <dct:description>A notch (blocking) filter.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source">
    <dct:description>The source (i.e. device, simulation, etc) of a Signal or Recording.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Simulation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Simulation">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Simulation">
    <dct:description>A computer simulation or modelling process that created the Signal or Recording.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Device">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Device">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Device">
    <dct:description>A physical device that converts the output of a sensor into a format able to be stored.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor">
    <dct:description>What actually captured a signal -- an electrode, transducer, etc.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <dct:description>A device that converts a measurable quantity into an electrical signal
           (e.g. thermistor, pressure sensor, strain gauge).</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Transducer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <dct:description>An electrical conductor in contact with non-conducting material, through which
            electrical activity can be measured.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SignalType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SignalType">
    <dct:description>The class or type of signal (e.g. EEG, ECG).</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#EventType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#EventType">
    <dct:description>Something which is the class or type of an Event.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity">
    <owl:equivalentClass rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity">
    <dct:description>Some measurement of time, either a particular point in time or some interval.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <owl:equivalentClass rdf:resource="http://www.w3.org/2006/time#Instant"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <dct:description>A particular point in time.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <owl:equivalentClass rdf:resource="http://www.w3.org/2006/time#Interval"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <dct:description>A period in time.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <dct:description>The class used to represent the types of measurement units used by signals.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <rdfs:comment>Measurement units would normally be entities in a specialised units of measure ontology.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <owl:equivalentClass rdf:resource="http://www.sbpax.org/uome/core.owl#UnitOfMeasurement"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <rdfs:seeAlso rdf:resource="http://www.sbpax.org/uome/list.html"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#RecordingGraph">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#RecordingGraph">
    <dct:description>A RDF graph containing Recording metadata, used for managing provenance.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SemanticTag">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SemanticTag">
    <dct:description>A tag used to classify a resource.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#ErrorTag">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#ErrorTag">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SemanticTag"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#ErrorTag">
    <dct:description>A tag to indicate that an annotation relates to some form of error.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <dct:description>Pre-filtering applied to a signal as part of collection.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdfs:domain rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdfs:range rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <dct:description>The Recording a Signal is part of.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdfs:domain rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdfs:range rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Recording"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <dct:description>What was used to collect or derive an electrical signal.</dct:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <rdfs:domain rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <rdfs:range rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="genid1">
    <rdf:first rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
