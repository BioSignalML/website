<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF xmlns:bsml="http://www.biosignalml.org/ontologies/2011/04/biosignalml#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:dctype="http://purl.org/dc/dcmitype/" xmlns:oa="http://www.w3.org/ns/openannotation/core/" xmlns:opb="http://bhi.washington.edu/OPB#" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:time="http://www.w3.org/2006/time#" xmlns:tl="http://purl.org/NET/c4dm/timeline.owl#" xmlns:uome-core="http://www.sbpax.org/uome/core.owl#" xmlns:xml="http://www.w3.org/XML/1998/namespace" xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/subject">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Recording">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Recording">
    <dcterms:description>A collection of Signals held as a named entity, all pertaining to one thing
          (the subject) and which have been recorded in the same session.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal">
    <dcterms:description>A sequence of periodic measurements of some physical quantity, ordered by some sampling
           dimension, normally time. A Signal is part of some Recording.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal">
    <rdfs:subClassOf rdf:resource="http://bhi.washington.edu/OPB#OPB_00002"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Event">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Event">
    <dcterms:description>Something that has occurred in time, possibly for some duration.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Event">
    <rdfs:subClassOf rdf:resource="http://bhi.washington.edu/OPB#OPB_00277"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Annotation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Annotation">
    <dcterms:description>A general note, comment, or qualitative measure about the whole of,
           or some portion of, a Recording, Signal or Event.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Annotation">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/openannotation/core/Annotation"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Process">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Process">
    <dcterms:description>Some method or algorithm applied to one or more Signals in order to derive
           information. The result could vary along a sampling dimension and be considered
           as a Signal.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Process">
    <rdfs:subClassOf rdf:resource="http://bhi.washington.edu/OPB#OPB_00424"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UniformSignal">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UniformSignal">
    <dcterms:description>A signal that has been sampled at a constant rate.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UniformSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SampleClock">
    <dcterms:description>An increasing sequence of sample coordinates.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SampleClock">
    <rdfs:comment>Several signals may use the same clock.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SampleClock">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter">
    <dcterms:description>The class of filter that has been applied to a signal during data collection.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#BP_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#BP_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#BP_Filter">
    <dcterms:description>A band-pass filter.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#HP_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#HP_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#HP_Filter">
    <dcterms:description>A high-pass filter.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#LP_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#LP_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#LP_Filter">
    <dcterms:description>A low-pass filter.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Notch_Filter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Notch_Filter">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Notch_Filter">
    <dcterms:description>A notch (blocking) filter.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source">
    <dcterms:description>The source (i.e. device, simulation, etc) of a Signal or Recording.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Simulation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Simulation">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Simulation">
    <dcterms:description>A computer simulation or modelling process that created the Signal or Recording.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Device">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Device">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Source"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Device">
    <dcterms:description>The physical device that saved the output of a sensor into a format able to be stored.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor">
    <dcterms:description>What actually captured a signal -- an electrode, transducer, etc.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <dcterms:description>A device that converts a measurable quantity into an electrical signal
           (e.g. thermistor, pressure sensor, strain gauge).</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Transducer">
    <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Transducer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <dcterms:description>An electrical conductor in contact with non-conducting material, through which
            electrical activity can be measured.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Electrode">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SignalType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#SignalType">
    <dcterms:description>The class or type of signal (e.g. EEG, ECG).</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#EventType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#EventType">
    <dcterms:description>Something which is the class or type of an Event.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity">
    <owl:equivalentClass rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity">
    <dcterms:description>Some measurement of time, either as a particular point in time or as some interval.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <owl:equivalentClass rdf:resource="http://www.w3.org/2006/time#Instant"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Instant">
    <dcterms:description>A particular point in time.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <rdfs:subClassOf rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#TemporalEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <owl:equivalentClass rdf:resource="http://www.w3.org/2006/time#Interval"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Interval">
    <dcterms:description>A period in time.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <dcterms:description>The class used to represent the types of measurement units used by signals.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <rdfs:comment>Measurement units would normally be entities in a specialised units of measure ontology.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <owl:equivalentClass rdf:resource="http://www.sbpax.org/uome/core.owl#UnitOfMeasurement"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#UnitOfMeasure">
    <rdfs:seeAlso rdf:resource="http://www.sbpax.org/uome/list.html"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#RecordingGraph">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#RecordingGraph">
    <dcterms:description>A RDF graph containing Recording metadata, used for managing provenance.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#ErrorTAG">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#ErrorTAG">
    <dcterms:description>A tag to indicate that an annotation relates to some form of error.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <dcterms:description>Pre-filtering applied to a signal as part of collection.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdfs:domain rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#preFilter">
    <rdfs:range rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Filter"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <dcterms:description>The Recording a Signal is part of.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdfs:domain rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#recording">
    <rdfs:range rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Recording"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <dcterms:description>What was used to collect or derive an electrical signal</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <rdfs:domain rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.biosignalml.org/ontologies/2011/04/biosignalml#sensor">
    <rdfs:range rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Sensor"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="genid1">
    <rdf:first rdf:resource="http://www.biosignalml.org/ontologies/2011/04/biosignalml#Signal"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="genid1">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
